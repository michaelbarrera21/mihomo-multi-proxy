[Unit]
Description=Proxy Manager Web Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/proxy-manager
ExecStart=/opt/proxy-manager/venv/bin/python -m uvicorn mihomo-multi-proxy.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
